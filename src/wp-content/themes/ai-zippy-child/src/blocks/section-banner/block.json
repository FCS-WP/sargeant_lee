{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy-child/section-banner",
	"version": "1.0.0",
	"title": "Section Banner",
	"category": "ai-zippy",
	"icon": "cover-image",
	"description": "A full-width banner with a background image and a centered heading.",
	"supports": {
		"html": false
	},
	"attributes": {
		"heading": {
			"type": "string",
			"default": "Our Concepts"
		},
		"bgUrl": {
			"type": "string",
			"default": ""
		},
		"bgId": {
			"type": "number",
			"default": 0
		},
		"paddingTop": {
			"type": "string",
			"default": "100px"
		},
		"paddingBottom": {
			"type": "string",
			"default": "100px"
		}
	},
	"textdomain": "ai-zippy-child",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
