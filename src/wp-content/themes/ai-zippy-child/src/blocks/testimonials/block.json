{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy-child/testimonials",
	"version": "1.0.0",
	"title": "Testimonials",
	"category": "ai-zippy",
	"icon": "format-quote",
	"description": "A full-width testimonials section with background image and a row of review cards.",
	"supports": {
		"html": false
	},
	"attributes": {
		"mode": {
			"type": "string",
			"default": "custom",
			"enum": ["custom", "shortcode"]
		},
		"shortcode": {
			"type": "string",
			"default": ""
		},
		"heading": {
			"type": "string",
			"default": "Our Happy Customers"
		},
		"bgUrl": {
			"type": "string",
			"default": ""
		},
		"bgId": {
			"type": "number",
			"default": 0
		},
		"items": {
			"type": "array",
			"default": [
				{ "quote": "", "author": "", "rating": 5 },
				{ "quote": "", "author": "", "rating": 5 },
				{ "quote": "", "author": "", "rating": 5 },
				{ "quote": "", "author": "", "rating": 5 }
			]
		},
		"paddingTop": {
			"type": "string",
			"default": "80px"
		},
		"paddingBottom": {
			"type": "string",
			"default": "80px"
		}
	},
	"textdomain": "ai-zippy-child",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
